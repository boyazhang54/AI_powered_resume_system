APP_NAME=Resume AI Analyzer
APP_ENV=local
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI is optional. When AI_API_KEY is empty, the service uses rule-based fallback.
AI_PROVIDER=openai_compatible
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# Cache is optional. When REDIS_URL is empty, local file cache is used.
REDIS_URL=
CACHE_DIR=.cache
DATABASE_PATH=resume_ai.db
AUTH_SECRET=please-change-this-secret
TOKEN_EXPIRE_HOURS=24
